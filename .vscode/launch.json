{
  "configurations": [
    {
      "command": "npm run dev --workspace=apps/backend",
      "name": "Backend",
      "request": "launch",
      "type": "node-terminal",
      "preLaunchTask": "infra: up",
      "postDebugTask": "infra: down",
      "presentation": {
        "hidden": true
      },
    },
    {
      "cwd": "${workspaceFolder}/apps/frontend",
      "name": "Frontend",
      "preLaunchTask": "vite: dev",
      "postDebugTask": "vite: stop",
      "request": "launch",
      "skipFiles": [
        "${workspaceFolder}/node_modules/**/*.js"
      ],
      "type": "msedge",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/frontend",
      "presentation": {
        "hidden": true
      }
    },
    {
      "cwd": "${workspaceFolder}/apps/frontend",
      "name": "Stories",
      "preLaunchTask": "stories",
      "request": "launch",
      "skipFiles": [
        "${workspaceFolder}/node_modules/**/*.js"
      ],
      "type": "msedge",
      "url": "http://localhost:61000",
      "webRoot": "${workspaceFolder}/apps/frontend",
    },
  ],
  "compounds": [
    {
      "name": "Magic3T",
      "configurations": ["Backend", "Frontend"],
    }
  ],
  "version": "0.2.0"
}
