{
  "configurations": [
    {
      "command": "npm run dev --workspace=apps/backend",
      "name": "Backend",
      "request": "launch",
      "type": "node-terminal",
      "preLaunchTask": "infra: up",
      "postDebugTask": "infra: down",
      "presentation": {
        "hidden": true
      },
    },
    {
      "name": "Frontend (Dev)",
      "request": "launch",
      "type": "node-terminal",
      "command": "npm run dev --workspace=apps/frontend",
      "presentation": {
        "hidden": true
      },
      "serverReadyAction": {
        "action": "debugWithChrome",
        "pattern": "Local:\\s+http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "webRoot": "${workspaceFolder}/apps/frontend",
        "killOnServerStop": true
      }
    },
    {
      "cwd": "${workspaceFolder}/apps/frontend",
      "name": "Frontend (Production)",
      "preLaunchTask": "frontend: prod",
      "postDebugTask": "frontend: down",
      "request": "launch",
      "skipFiles": [
        "${workspaceFolder}/node_modules/**/*.js"
      ],
      "type": "msedge",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/frontend"
    },
    {
      "cwd": "${workspaceFolder}/apps/frontend",
      "name": "Stories",
      "preLaunchTask": "stories",
      "request": "launch",
      "skipFiles": [
        "${workspaceFolder}/node_modules/**/*.js"
      ],
      "type": "msedge",
      "url": "http://localhost:61000",
      "webRoot": "${workspaceFolder}/apps/frontend",
    },
  ],
  "compounds": [
    {
      "name": "Magic3T",
      "configurations": ["Backend", "Frontend (Dev)"],
    }
  ],
  "version": "0.2.0"
}
