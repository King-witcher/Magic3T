{
	"version": "2.0.0",
  "inputs": [
    {
      "id": "backend-url",
      "type": "pickString",
      "description": "Select the backend URL",
      "default": "Local",
      "options": [
        {
          "label": "Local",
          "value": "http://localhost:4000"
        },
        {
          "label": "Production",
          "value": "https://api.magic3t.com.br"
        }
      ]
    },
    {
      "id": "migration-name",
      "type": "promptString",
      "description": "Enter a name for the new migration (e.g., 'create-users-table')",
      "default": "new-migration"
    }
  ],
	"tasks": [
    {
      "label": "typecheck: backend",
      "detail": "Starts a background tsc --watch that reports all type errors in the VSCode Problems panel.",
      "icon": {
        "id": "eye-watch",
        "color": "terminal.ansiCyan"
      },
      "type": "shell",
      "command": "npx",
      "args": [
        "tsc",
        "--watch",
        "--noEmit",
        "--project",
        "apps/backend/tsconfig.json"
      ],
      "group": "test",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "presentation": {
        "echo": false,
        "reveal": "never",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "typecheck: frontend",
      "detail": "Starts a background tsc --watch that reports all type errors in the VSCode Problems panel.",
      "icon": {
        "id": "eye-watch",
        "color": "terminal.ansiCyan"
      },
      "type": "shell",
      "command": "npx",
      "args": [
        "tsc",
        "--watch",
        "--noEmit",
        "--project",
        "apps/frontend/tsconfig.json"
      ],
      "group": "test",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "presentation": {
        "echo": false,
        "reveal": "never",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Create Migration",
      "detail": "Creates a new migration",
      "icon": {
        "id": "database",
        "color": "terminal.ansiYellow"
      },
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "new",
        "${input:migration-name}"
      ],
      "options": {
        "cwd": "apps/migrations"
      },
      "problemMatcher": {
        "owner": "migrations",
        "pattern": {
          "regexp": "^([^\\\\s].*)\\\\((\\\\d+,\\\\d+)\\\\):\\\\s*(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        }
      },
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Run Migrations",
      "detail": "Runs all pending migrations",
      "icon": {
        "id": "database",
        "color": "terminal.ansiBlue"
      },
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "migrate"
      ],
      "problemMatcher": {
        "owner": "migrations",
        "pattern": {
          "regexp": "^([^\\\\s].*)\\\\((\\\\d+,\\\\d+)\\\\):\\\\s*(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        }
      },
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Clear Migrations",
      "detail": "Reverts all migrations in the database",
      "icon": {
        "id": "database",
        "color": "terminal.ansiRed"
      },
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "migrate:clear"
      ],
      "problemMatcher": {
        "owner": "migrations",
        "pattern": {
          "regexp": "^([^\\\\s].*)\\\\((\\\\d+,\\\\d+)\\\\):\\\\s*(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        }
      },
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "infra: up",
      "type": "docker-compose",
      "hide": true,
      "dockerCompose": {
        "up": {
          "detached": true,
          "build": false
        },
        "files": [
          "${workspaceFolder}/compose.yaml"
        ]
      },
      "icon": {
        "id": "server",
        "color": "terminal.ansiGreen"
      }
    },
    {
      "label": "infra: down",
      "type": "docker-compose",
      "hide": true,
      "dockerCompose": {
        "down": {
          "build": false
        },
        "files": [
          "${workspaceFolder}/compose.yaml"
        ]
      },
      "icon": {
        "id": "server",
        "color": "terminal.ansiRed"
      }
    },
    {
      "label": "vite: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "apps/frontend",
        "env": {
          "VITE_API_URL": "${input:backend-url}"
        }
      },
      "isBackground": true,
      "icon": {
        "id": "run",
        "color": "terminal.ansiGreen"
      },
      "problemMatcher": [
        {
          "owner": "vite",
          "pattern": {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "."
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "hide": true
    },
    {
      "label": "vite: stop",
      "type": "shell",
      "command": "npx kill-port 3000 -y",
      "hide": true,
      "icon": {
        "id": "run",
        "color": "terminal.ansiRed"
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      }
    },
    {
      "label": "stories",
      "type": "shell",
      "command": "npm run stories",
      "hide": true,
      "options": {
        "cwd": "apps/frontend"
      },
      "isBackground": true,
      "icon": {
        "id": "run",
        "color": "terminal.ansiGreen"
      },
      "problemMatcher": [
        {
          "owner": "vite",
          "pattern": {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "."
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "build: backend",
      "hide": true,
      "icon": {
        "id": "tools",
        "color": "terminal.ansiWhite"
      },
      "type": "shell",
      "options": {
        "cwd": "apps/backend"
      },
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "build: frontend",
      "hide": true,
      "icon": {
        "id": "tools",
        "color": "terminal.ansiWhite"
      },
      "type": "shell",
      "options": {
        "cwd": "apps/frontend"
      },
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "biome lint",
      "hide": true,
      "icon": {
        "id": "tools",
        "color": "terminal.ansiWhite"
      },
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "lint"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "build",
      "hide": true,
      "dependsOn": [
        "build: backend",
        "build: frontend",
        "biome lint"
      ],
      "group": {
        "isDefault": true,
        "kind": "build"
      },
      "dependsOrder": "parallel"
    }
  ]
}
